# macOS / editor
.DS_Store

# Dependencies
node_modules/
app/node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Environment / secrets
.env
.env.*
!.env.example

# Runtime data (never publish)
data/**
app/data/**

# Keep empty runtime folders in repo
!data/.gitkeep
!data/uploads/.gitkeep
!data/tmp_restore/.gitkeep
!app/data/.gitkeep
!app/data/uploads/.gitkeep
!app/data/tmp_restore/.gitkeep

# DB artifacts
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Backup/export artifacts
*.zip
*.tar
*.tar.gz
*.bak
*.dump
*.sql
